<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hydroponic_seeding_tree" model="ir.ui.view">
        <field name="name">hydroponic.seeding.list</field>
        <field name="model">hydroponic.seeding</field>
        <field name="arch" type="xml">
            <list string="Daftar Pembibitan">
                <field name="name"/>
                <field name="product_id"/>
                <field name="start_date"/>
                <field name="duration"/>
                <field name="estimated_transfer_date"/>
                <field name="qty_seeding"/>
                <field name="state" widget="badge" 
                       decoration-info="state == 'draft'" 
                       decoration-warning="state == 'in_progress'" 
                       decoration-success="state == 'transferred'" 
                       decoration-danger="state == 'cancel'"/>
            </list>
        </field>
    </record>

    <record id="view_hydroponic_seeding_form" model="ir.ui.view">
        <field name="name">hydroponic.seeding.form</field>
        <field name="model">hydroponic.seeding</field>
        <field name="arch" type="xml">
            <form string="Form Pembibitan">
                <header>
                    <button name="action_cancel" type="object" string="Gagal / Cancel" 
                            class="btn-danger" 
                            invisible="state in ('transferred', 'cancel')"/>
                    
                    <field name="state" widget="statusbar" options="{'clickable': '1'}" 
                           statusbar_visible="draft,in_progress,transferred"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Informasi Tanaman">
                            <field name="product_id" placeholder="Pilih benih/sayuran..."/>
                            <field name="qty_seeding"/>
                        </group>
                        <group string="Siklus Waktu">
                            <field name="start_date"/>
                            <field name="duration"/>
                            <field name="estimated_transfer_date" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_hydroponic_seeding_search" model="ir.ui.view">
        <field name="name">hydroponic.seeding.search</field>
        <field name="model">hydroponic.seeding</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Kode Batch"/>
                <field name="product_id" string="Nama Sayuran"/>
                <filter string="Sembunyikan Gagal" name="hide_cancel" domain="[('state', '!=', 'cancel')]"/>
            </search>
        </field>
    </record>

    <record id="action_hydroponic_seeding" model="ir.actions.act_window">
        <field name="name">Pembibitan (Seeding)</field>
        <field name="res_model">hydroponic.seeding</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_hide_cancel': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Belum ada data pembibitan.
            </p><p>
                Klik tombol "New" untuk memulai pencatatan batch pembibitan baru Anda.
            </p>
        </field>
    </record>
</odoo>