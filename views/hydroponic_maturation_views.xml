<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- View untuk Master Talang -->
    <record id="view_hydroponic_talang_tree" model="ir.ui.view">
        <field name="name">hydroponic.talang.list</field>
        <field name="model">hydroponic.talang</field>
        <field name="arch" type="xml">
            <list string="Daftar Talang" editable="bottom">
                <field name="name"/>
                <field name="capacity"/>
                <field name="current_load"/>
                <field name="remaining_capacity" decoration-danger="remaining_capacity &lt;= 0" decoration-success="remaining_capacity &gt; 0" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="action_hydroponic_talang" model="ir.actions.act_window">
        <field name="name">Master Talang</field>
        <field name="res_model">hydroponic.talang</field>
        <field name="view_mode">list</field>
    </record>

    <!-- View untuk Menu Pendewasaan -->
    <record id="view_hydroponic_maturation_tree" model="ir.ui.view">
        <field name="name">hydroponic.maturation.list</field>
        <field name="model">hydroponic.maturation</field>
        <field name="arch" type="xml">
            <list string="Daftar Pendewasaan" create="0">
                <field name="batch_name"/>
                <field name="juvenile_product_id"/>
                <field name="qty_unallocated" decoration-warning="qty_unallocated &gt; 0" widget="badge"/>
                <field name="state" widget="badge" decoration-info="state == 'process'" decoration-success="state == 'done'"/>
            </list>
        </field>
    </record>

    <record id="view_hydroponic_maturation_form" model="ir.ui.view">
        <field name="name">hydroponic.maturation.form</field>
        <field name="model">hydroponic.maturation</field>
        <field name="arch" type="xml">
            <form string="Form Pendewasaan" create="0">
                <header>
                    <button name="action_start_process" type="object" string="Mulai Masuk Talang" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_mark_done" type="object" string="Tutup Batch (Selesai)" invisible="state != 'process'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,process,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="batch_name"/></h1>
                    </div>
                    <group>
                        <group string="Sumber Peremajaan">
                            <field name="juvenile_product_id"/>
                            <field name="qty_entered"/>
                            <field name="qty_unallocated" class="font-weight-bold text-danger"/>
                        </group>
                        <group string="Pengaturan Panen">
                            <field name="harvest_product_id" placeholder="Pilih produk hasil akhir..." readonly="state == 'done'"/>
                        </group>
                    </group>
                    
                    <!-- TAB TERPISAH: Alokasi & Panen -->
                    <notebook>
                        <page string="Alokasi Pindah Tanam">
                            <field name="line_ids" readonly="state == 'done'" context="{'default_transfer_date': context_today()}">
                                <!-- Baris akan berwarna hijau jika sudah selesai (Sisa = 0) -->
                                <list editable="bottom" decoration-success="is_done == True">
                                    <field name="talang_id" options="{'no_create': True}" readonly="is_done == True"
                                           domain="['|', ('remaining_capacity', '&gt;', 0), ('id', '=', talang_id)]"/>
                                    <field name="transfer_date" readonly="is_done == True"/>
                                    <field name="qty_transfer" readonly="is_done == True" sum="Total Alokasi"/>
                                    
                                    <!-- Informasi Sisa untuk memantau -->
                                    <field name="qty_harvested" readonly="1" optional="show"/>
                                    <field name="qty_remaining" readonly="1" string="Sisa Blm Panen" decoration-danger="qty_remaining &gt; 0" decoration-success="qty_remaining == 0"/>
                                    <field name="is_done" column_invisible="True"/>
                                </list>
                            </field>
                        </page>
                        
                        <page string="Input Panen" invisible="state == 'draft'">
                            <field name="harvest_line_ids" readonly="state == 'done'">
                                <list editable="bottom">
                                    <!-- Filter: Hanya memunculkan Talang dari batch ini yang sisanya belum 0 -->
                                    <field name="allocation_id" options="{'no_create': True}" 
                                           domain="[('maturation_id', '=', parent.id), ('is_done', '=', False)]"/>
                                    
                                    <field name="qty_remaining_info" readonly="1" decoration-info="1"/>
                                    <field name="harvest_date"/>
                                    <field name="qty_harvested" sum="Total Panen"/>
                                    <field name="qty_failed" sum="Total Gagal"/>
                                </list>
                            </field>
                            <p class="text-muted mt-2">
                                <em>Klik "Add a line" berkali-kali untuk memasukkan riwayat panen pada hari yang berbeda. Kuota Master Talang akan otomatis bertambah kembali setiap kali ada panen (Sisa berkurang).</em>
                            </p>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hydroponic_maturation" model="ir.actions.act_window">
        <field name="name">Pendewasaan &amp; Panen</field>
        <field name="res_model">hydroponic.maturation</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>