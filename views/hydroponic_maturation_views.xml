<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- View untuk Master Talang -->
    <record id="view_hydroponic_talang_tree" model="ir.ui.view">
        <field name="name">hydroponic.talang.list</field>
        <field name="model">hydroponic.talang</field>
        <field name="arch" type="xml">
            <list string="Daftar Talang" editable="bottom">
                <field name="name"/>
                <field name="capacity"/>
                <field name="status" widget="badge" decoration-success="status == 'available'" decoration-warning="status == 'in_use'"/>
            </list>
        </field>
    </record>

    <record id="action_hydroponic_talang" model="ir.actions.act_window">
        <field name="name">Master Talang</field>
        <field name="res_model">hydroponic.talang</field>
        <field name="view_mode">list</field>
    </record>

    <!-- View untuk Menu Pendewasaan -->
    <record id="view_hydroponic_maturation_tree" model="ir.ui.view">
        <field name="name">hydroponic.maturation.list</field>
        <field name="model">hydroponic.maturation</field>
        <field name="arch" type="xml">
            <list string="Daftar Pendewasaan" create="0">
                <field name="batch_name"/>
                <field name="juvenile_product_id"/>
                <field name="harvest_product_id"/>
                <field name="state" widget="badge" decoration-info="state == 'process'" decoration-success="state == 'done'"/>
            </list>
        </field>
    </record>

    <record id="view_hydroponic_maturation_form" model="ir.ui.view">
        <field name="name">hydroponic.maturation.form</field>
        <field name="model">hydroponic.maturation</field>
        <field name="arch" type="xml">
            <form string="Form Pendewasaan" create="0">
                <header>
                    <button name="action_start_process" type="object" string="Mulai Masuk Talang" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_mark_done" type="object" string="Tutup Batch (Selesai)" invisible="state != 'process'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,process,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="batch_name"/></h1>
                    </div>
                    <group>
                        <group string="Sumber Peremajaan (Read-only)">
                            <field name="juvenile_product_id"/>
                            <field name="qty_entered"/>
                        </group>
                        <group string="Pengaturan Panen">
                            <field name="harvest_product_id" placeholder="Pilih produk hasil akhir..." readonly="state == 'done'"/>
                        </group>
                    </group>
                    
                    <!-- Tabel Fleksibel (Add a Line) -->
                    <notebook>
                        <page string="Alokasi Talang &amp; Input Panen">
                            <field name="line_ids" readonly="state == 'done'">
                                <list editable="bottom" decoration-muted="is_harvested == True">
                                    <field name="talang_id" options="{'no_create': True}" readonly="is_harvested == True"/>
                                    <field name="qty_transfer" readonly="is_harvested == True"/>
                                    
                                    <!-- Area Panen -->
                                    <field name="harvest_date" readonly="is_harvested == True"/>
                                    <field name="qty_failed" readonly="is_harvested == True"/>
                                    <field name="qty_harvested" readonly="is_harvested == True"/>
                                    
                                    <field name="is_harvested" widget="boolean_toggle"/>
                                </list>
                            </field>
                            <p class="text-muted mt-2">
                                <em>Catatan: Centang tombol panen di sebelah kanan untuk menyetor hasil ke Inventory dan mengosongkan Talang.</em>
                            </p>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hydroponic_maturation" model="ir.actions.act_window">
        <field name="name">Pendewasaan &amp; Panen</field>
        <field name="res_model">hydroponic.maturation</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>